<Window x:Class="傻逼网易云.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:傻逼网易云"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10,10,0,-5">
        <Button Content="录入" HorizontalAlignment="Left" Margin="148,162,0,0" VerticalAlignment="Top" FontFamily="Microsoft YaHei UI Light" FontSize="20" Click="Button_Click"/>
        <Button x:Name="tp" Content="播放" HorizontalAlignment="Left" Margin="216,251,0,0" VerticalAlignment="Top" FontFamily="Microsoft YaHei UI Light" FontSize="20" Click="Button_Click_1"/>
        <Label x:Name="musicshow" Content="暂未选择歌曲" HorizontalAlignment="Center" Margin="0,37,0,0" VerticalAlignment="Top" Height="64" Width="714" FontFamily="Microsoft JhengHei" FontSize="48"/>
        <MediaElement x:Name="music" LoadedBehavior="Manual" UnloadedBehavior="Manual" Margin="0,22,0,-22" MediaEnded="change_Click"/>
        <ListBox x:Name="listt" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="370,220,0,10" FontSize="20" FontFamily="Microsoft JhengHei Light" SelectionChanged="listt_SelectionChanged"/>
        <Button x:Name="change" Content="下一首" HorizontalAlignment="Left" Margin="74,251,0,0" VerticalAlignment="Top" FontSize="18" FontFamily="Microsoft YaHei UI Light" Click="change_Click"/>
        <Button x:Name="rechange" Content="上一首" HorizontalAlignment="Left" Margin="74,215,0,0" VerticalAlignment="Top" Height="31" Width="58" FontSize="18" FontFamily="Microsoft YaHei UI Light" Click="rechange_Click"/>
    </Grid>
</Window>
