<Window x:Class="u盘音乐播放器.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:u盘音乐播放器"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label x:Name="title" Content=" 正在更新列表当中......" HorizontalAlignment="Left" Margin="40,10,0,0" VerticalAlignment="Top" Width="698" Height="56" FontSize="36"/>
        <ListBox x:Name="alllist" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="452,204,0,0" FontSize="24" SelectionChanged="alllistchanged"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="352,204,0,0" VerticalAlignment="Top" Height="29" Width="74"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="352,204,0,0" VerticalAlignment="Top" Height="29" Width="74"/>
        <Button Content="总表" HorizontalAlignment="Left" Margin="352,204,0,0" VerticalAlignment="Top" Height="29" Width="84" FontSize="20" FontFamily="Microsoft YaHei UI Light" Click="Button_Click"/>
        <Button Content="缓音乐" HorizontalAlignment="Left" Margin="352,238,0,0" VerticalAlignment="Top" Height="34" Width="84" FontSize="20" FontFamily="Microsoft YaHei UI Light" Click="Button_Click_1"/>
        <Button Content="烈音乐" HorizontalAlignment="Left" Margin="353,277,0,0" VerticalAlignment="Top" Height="42" Width="83" FontSize="20" FontFamily="Microsoft YaHei UI Light" Click="Button_Click_2"/>
        <Button Content="其它音乐" HorizontalAlignment="Left" Margin="353,324,0,0" VerticalAlignment="Top" Height="32" Width="83" FontSize="18" FontFamily="Microsoft YaHei UI Light" Click="Button_Click_3"/>
        <ListBox x:Name="awakelist" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="452,204,0,0" FontSize="24" Visibility="Collapsed" SelectionChanged="awakelistchanged"/>
        <ListBox x:Name="highlist" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="452,204,0,0" FontSize="24" Visibility="Collapsed" SelectionChanged="highlistchanged"/>
        <ListBox x:Name="anotherlist" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="452,204,0,0" FontSize="24" Visibility="Collapsed" SelectionChanged="anotherlistchanged"/>
        <MediaElement x:Name="player" LoadedBehavior="Manual"/>
        <Button Content="上一首" HorizontalAlignment="Left" Margin="26,232,0,0" VerticalAlignment="Top" Height="36" Width="76" FontSize="22" Click="Button_Click_4"/>
        <Button x:Name="next" Content="下一首" HorizontalAlignment="Left" Margin="107,232,0,0" VerticalAlignment="Top" Height="36" Width="69" FontSize="22" Click="Button_Click_5"/>
        <Button x:Name="model" Content="切换播放模式" HorizontalAlignment="Left" Margin="26,282,0,0" VerticalAlignment="Top" Width="136" Height="37" FontSize="22" Click="Button_Click_6"/>
        <Button Content="更新歌曲列表" HorizontalAlignment="Left" Margin="311,361,0,0" VerticalAlignment="Top" Height="29" Width="125" FontSize="20" Click="Button_Click_7"/>
        <Label x:Name="oncelabel" Content="刷新中" HorizontalAlignment="Left" Margin="452,164,0,0" VerticalAlignment="Top" Width="96" Height="35" FontSize="22"/>
        <Label x:Name="secondlabel" Content="顺序播放" HorizontalAlignment="Left" Margin="40,128,0,0" VerticalAlignment="Top" FontSize="20" Height="35" Width="92"/>
        <Slider x:Name="bar" HorizontalAlignment="Left" Margin="40,93,0,0" VerticalAlignment="Top" Width="508" Height="18" ValueChanged="Slider_ValueChanged" Thumb.DragStarted="st" Thumb.DragCompleted="co"/>
        <Button x:Name="stsp" Content="暂停" HorizontalAlignment="Left" Margin="294,136,0,0" VerticalAlignment="Top" Height="27" Width="52" FontSize="20" Click="stsp_Click"/>
        <Label x:Name="show" Content="" HorizontalAlignment="Left" Margin="586,89,0,0" VerticalAlignment="Top" Width="191" FontSize="18"/>
    </Grid>
</Window>
